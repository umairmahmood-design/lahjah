rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — read any authenticated user's profile (needed for copy-team listing),
    // write only to your own document (onboarding, profile updates).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Copy requests — any authenticated user can read and write.
    match /copyRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // Settings (guidelines, admins) — any authenticated user can read and write.
    match /settings/{document} {
      allow read, write: if request.auth != null;
    }

    // Notifications — any authenticated user can create;
    // users can only read notifications addressed to them.
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Chat conversations and messages — users can only access their own chats.
    match /chats/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
